#!/command/with-contenv bashio
# shellcheck shell=bash
# vim: ft=bash
# ==============================================================================
# Initialize Samba SSL Certificates
# Generates a CA certificate, server.key and server.cert for Samba with the
# correct FQDN. The CA cert is stored as /config/ca.cert for client trust.
# Certificates are stored in /config and only regenerated if missing or invalid
# ==============================================================================
set -euo pipefail
exec 2>&1
trap 'bashio::log.error "init-smbd/run failed at line ${LINENO} (exit code: ${?})"' ERR

CERT_DIR="/ssl/sambanas/"
CA_KEY_FILE="${CERT_DIR}/ca.key"
CA_CERT_FILE="${CERT_DIR}/ca.crt"
KEY_FILE="${CERT_DIR}/server.key"
CERT_FILE="${CERT_DIR}/server.crt"

# Ensure certificate directory exists before any read/write operation.
if [ ! -d "${CERT_DIR}" ]; then
  bashio::log.info "Creating certificate directory '${CERT_DIR}'"
  if ! mkdir -p "${CERT_DIR}"; then
    bashio::log.error "Failed to create certificate directory '${CERT_DIR}'"
    exit 1
  fi
fi



# Read hostname from API or use default
HOSTNAME=$(bashio::info.hostname)
if bashio::var.is_empty "${HOSTNAME}" || [ "${HOSTNAME}" == "null" ]; then
  bashio::log.warning "Can't read hostname, using default."
  HOSTNAME="homeassistant"
fi

# Try to get the domain from supervisor
#DOMAIN=$(bashio::host.domain)
#if bashio::var.is_empty "${DOMAIN}" || [ "${DOMAIN}" == "null" ]; then
  DOMAIN="local"
#fi

FQDN="${HOSTNAME}.${DOMAIN}"
bashio::log.info "Using FQDN: ${FQDN}"

# Function to check if certificate is valid
check_certificate_validity() {
  local cert_file=$1
  local expected_fqdn=$2
  
  # Check if certificate file exists
  if [ ! -f "${cert_file}" ]; then
    bashio::log.debug "Certificate file does not exist"
    return 1
  fi
  
  # Check if certificate is expired
  if ! openssl x509 -checkend 86400 -noout -in "${cert_file}" 2>/dev/null; then
    bashio::log.info "Certificate is expired or will expire within 24 hours"
    return 1
  fi
  
  # Subject must contain a CN value (CN can be any value, but must exist)
  local subject_line
  subject_line=$(openssl x509 -noout -subject -nameopt RFC2253 -in "${cert_file}" 2>/dev/null)
  if ! printf '%s\n' "${subject_line}" | grep -Eq '(^|,)CN='; then
    bashio::log.info "Certificate subject does not include CN"
    return 1
  fi

  # SAN must include all required DNS names for QUIC/Samba access.
  local san_output
  san_output=$(openssl x509 -noout -ext subjectAltName -in "${cert_file}" 2>/dev/null)
  local san_name
  for san_name in "${expected_fqdn}" "${HOSTNAME}" "${HOSTNAME}." "localhost"; do
    if ! printf '%s\n' "${san_output}" | grep -Fq "DNS:${san_name}"; then
      bashio::log.info "Certificate SAN does not include required DNS name '${san_name}'"
      return 1
    fi
  done

  # Key usage must include digitalSignature.
  local key_usage_output
  key_usage_output=$(openssl x509 -noout -ext keyUsage -in "${cert_file}" 2>/dev/null)
  if ! printf '%s\n' "${key_usage_output}" | grep -Eiq 'Digital Signature'; then
    bashio::log.info "Certificate key usage does not include Digital Signature"
    return 1
  fi

  # EKU must include serverAuth (OID 1.3.6.1.5.5.7.3.1).
  local eku_output
  eku_output=$(openssl x509 -noout -ext extendedKeyUsage -in "${cert_file}" 2>/dev/null)
  if ! printf '%s\n' "${eku_output}" | grep -Eiq '1\.3\.6\.1\.5\.5\.7\.3\.1|TLS Web Server Authentication'; then
    bashio::log.info "Certificate EKU does not include Server Authentication"
    return 1
  fi

  # Signature algorithm/hash must be SHA256 or stronger.
  local sig_alg
  sig_alg=$(openssl x509 -noout -text -in "${cert_file}" 2>/dev/null | sed -n 's/^ *Signature Algorithm: //p' | head -n 1 | tr '[:upper:]' '[:lower:]')
  case "${sig_alg}" in
    *sha512*|*sha384*|*sha256*)
      ;;
    *)
      bashio::log.info "Certificate signature algorithm '${sig_alg}' is weaker than SHA256"
      return 1
      ;;
  esac

  # Public key algorithm must be RSA >= 2048 or ECDSA P-256 or stronger.
  local cert_text
  cert_text=$(openssl x509 -noout -text -in "${cert_file}" 2>/dev/null)
  local pubkey_alg
  pubkey_alg=$(printf '%s\n' "${cert_text}" | sed -n 's/^ *Public Key Algorithm: //p' | head -n 1 | tr '[:upper:]' '[:lower:]')

  if [ "${pubkey_alg}" = "rsaencryption" ]; then
    local rsa_bits
    rsa_bits=$(printf '%s\n' "${cert_text}" | sed -n 's/^ *Public-Key: (\([0-9][0-9]*\) bit).*/\1/p' | head -n 1)
    if [ -z "${rsa_bits}" ] || [ "${rsa_bits}" -lt 2048 ]; then
      bashio::log.info "Certificate RSA key length '${rsa_bits}' is less than 2048 bits"
      return 1
    fi
  elif [ "${pubkey_alg}" = "id-ecpublickey" ]; then
    local ec_curve
    ec_curve=$(printf '%s\n' "${cert_text}" | sed -n 's/^ *ASN1 OID: //p' | head -n 1 | tr '[:upper:]' '[:lower:]')
    case "${ec_curve}" in
      prime256v1|secp256r1|secp384r1|secp521r1)
        ;;
      *)
        bashio::log.info "Certificate EC curve '${ec_curve}' is not P-256 or stronger"
        return 1
        ;;
    esac
  else
    bashio::log.info "Unsupported public key algorithm '${pubkey_alg}'"
    return 1
  fi
  
  bashio::log.debug "Certificate is compliant and valid for '${expected_fqdn}'"
  return 0
}

# Check if all certificates exist and are valid
if [ -f "${KEY_FILE}" ] && [ -f "${CERT_FILE}" ] && [ -f "${CA_CERT_FILE}" ]; then
  if check_certificate_validity "${CERT_FILE}" "${FQDN}"; then
    bashio::log.info "SSL certificates are valid and up to date"
    exit 0
  else
    bashio::log.info "SSL certificates need to be regenerated"
  fi
else
  bashio::log.info "SSL certificates not found, generating new ones"
fi

bashio::log.info "Generating SSL certificates for ${FQDN}"

# Generate CA only when missing or expired.
if [ -f "${CA_KEY_FILE}" ] && [ -f "${CA_CERT_FILE}" ] \
  && openssl x509 -checkend 86400 -noout -in "${CA_CERT_FILE}" 2>/dev/null; then
  bashio::log.info "Reusing existing CA certificate and private key"
else
  bashio::log.info "Generating new CA certificate and private key"
  rm -f "${CA_KEY_FILE}" "${CA_CERT_FILE}" "${CA_CERT_FILE}.srl"

  openssl genrsa -out "${CA_KEY_FILE}" 2048 2>/dev/null
  if [ $? -ne 0 ]; then
    bashio::log.error "Failed to generate CA private key"
    exit 1
  fi

  # Generate CA self-signed certificate valid for 10 years
  openssl req -new -x509 -key "${CA_KEY_FILE}" -out "${CA_CERT_FILE}" -days 3650 \
    -sha256 \
    -subj "/C=IT/ST=Italy/L=Milan/O=HomeAssistant/OU=SambaNAS-CA/CN=SambaNAS-CA" 2>/dev/null
  if [ $? -ne 0 ]; then
    bashio::log.error "Failed to generate CA certificate"
    rm -f "${CA_KEY_FILE}" "${CA_CERT_FILE}" "${CA_CERT_FILE}.srl"
    exit 1
  fi
fi

# Generate server private key
openssl genrsa -out "${KEY_FILE}" 2048 2>/dev/null
if [ $? -ne 0 ]; then
  bashio::log.error "Failed to generate server private key"
  exit 1
fi

# Generate server CSR
CSR_FILE=$(mktemp)
openssl req -new -key "${KEY_FILE}" -out "${CSR_FILE}" \
  -subj "/C=IT/ST=Italy/L=Milan/O=HomeAssistant/OU=SambaNAS/CN=${FQDN}" 2>/dev/null
if [ $? -ne 0 ]; then
  bashio::log.error "Failed to generate server CSR"
  rm -f "${KEY_FILE}" "${CSR_FILE}"
  exit 1
fi

# Write SAN extension file
EXT_FILE=$(mktemp)
cat > "${EXT_FILE}" <<EOF
basicConstraints=CA:FALSE
keyUsage=digitalSignature
extendedKeyUsage=serverAuth
subjectAltName=DNS:${FQDN},DNS:${HOSTNAME},DNS:${HOSTNAME}.,DNS:localhost
EOF

# Sign server certificate with the CA
openssl x509 -req -in "${CSR_FILE}" -CA "${CA_CERT_FILE}" -CAkey "${CA_KEY_FILE}" \
  -CAcreateserial -out "${CERT_FILE}" -days 3650 \
  -sha256 \
  -extfile "${EXT_FILE}" 2>/dev/null
SIGN_STATUS=$?
rm -f "${CSR_FILE}" "${EXT_FILE}"

if [ "${SIGN_STATUS}" -ne 0 ]; then
  bashio::log.error "Failed to sign server certificate"
  rm -f "${KEY_FILE}" "${CERT_FILE}" "${CA_CERT_FILE}.srl"
  exit 1
fi

# Verify certificate generation
openssl x509 -noout -subject -in "${CERT_FILE}"

# Set appropriate permissions
chmod 600 "${CA_KEY_FILE}"
chmod 644 "${CA_CERT_FILE}"
chmod 600 "${KEY_FILE}"
chmod 644 "${CERT_FILE}"

bashio::log.info "SSL certificates generated successfully"
bashio::log.info "CA certificate: ${CA_CERT_FILE}"
bashio::log.info "Certificate: ${CERT_FILE}"
bashio::log.info "Private key: ${KEY_FILE}"

exit 0
